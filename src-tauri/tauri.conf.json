{
  "version": "1.5.3",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "Clash Ultra",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources"],
    "publisher": "Clash Ultra",
    "externalBin": ["sidecar/ultra-mihomo", "sidecar/ultra-mihomo-alpha"],
    "copyright": "GNU General Public License v3.0",
    "category": "DeveloperTool",
    "shortDescription": "Clash Ultra",
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://localhost:3300/",
    "removeUnusedCommands": true
  },
  "productName": "Clash Ultra",
  "identifier": "app.clash-ultra.desktop",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/H1d3rOne/clash-ultra/releases/download/updater/update.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEQ0QyM0E4MjEzNTc0QTAKUldTZ2REVWhxQ1BOalNWcUgyVXhhdFRpZ1FlTjViRFl6c0MvbDN2TlFpZW83ZTE0bHZvVkIvYzgK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["clash", "clash-ultra"]
      }
    }
  },
  "app": {
    "security": {
      "capabilities": ["desktop-capability", "migrated"],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  }
}
